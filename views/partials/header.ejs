<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | Echo-1 Labs' : 'Echo-1 Labs — Business Lifecycle Management' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Echo-1 Labs accelerates business lifecycles through AI-enhanced automations, agentic systems, and management support for founder-led companies.' %>" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<nav class="nav">
  <div class="container nav__inner">
    <!-- E1 Orbit Mark -->
    <a href="/" class="nav__logo">
      <svg class="orbit-mark" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Orbit dashed arc ring -->
        <circle cx="14" cy="14" r="11" stroke="#FF7515" stroke-width="1.5" stroke-dasharray="3 2.5" opacity="0.7"/>
        <!-- Compass star center -->
        <circle cx="14" cy="14" r="2.5" fill="#FF7515"/>
        <!-- 8-point compass marks -->
        <line x1="14" y1="3" x2="14" y2="7" stroke="#FF7515" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="14" y1="21" x2="14" y2="25" stroke="#FF7515" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3" y1="14" x2="7" y2="14" stroke="#FF7515" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="21" y1="14" x2="25" y2="14" stroke="#FF7515" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="5.9" y1="5.9" x2="8.7" y2="8.7" stroke="#FF7515" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
        <line x1="19.3" y1="19.3" x2="22.1" y2="22.1" stroke="#FF7515" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
        <line x1="22.1" y1="5.9" x2="19.3" y2="8.7" stroke="#FF7515" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
        <line x1="8.7" y1="19.3" x2="5.9" y2="22.1" stroke="#FF7515" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
      </svg>
      Echo-1 Labs
    </a>

    <ul class="nav__links">
      <li><a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a></li>
      <li><a href="/ai-readiness" class="<%= page === 'ai-readiness' ? 'active' : '' %>">AI Readiness</a></li>
      <li><a href="/products" class="<%= page === 'products' ? 'active' : '' %>">Products</a></li>
      <li><a href="/about" class="<%= page === 'about' ? 'active' : '' %>">About</a></li>
    </ul>

    <a href="/contact" class="nav__cta">Schedule a Call</a>
  </div>
</nav>
